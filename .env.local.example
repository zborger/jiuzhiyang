# =============================================================================
# 化学教师网站环境变量配置示例
# =============================================================================
# 复制此文件为 .env.local 并填入实际值
# 注意：.env.local 文件不应提交到 Git 仓库

# -----------------------------------------------------------------------------
# 网站基础配置
# -----------------------------------------------------------------------------

# 网站URL（必填）
# 用途：SEO规范URL、Open Graph标签、sitemap生成
# 示例：https://chemistry-teacher.com
# 相关需求：9.3, 9.4, 9.8
NEXT_PUBLIC_SITE_URL=https://your-domain.com

# -----------------------------------------------------------------------------
# AI功能配置（未来功能 - V3+）
# -----------------------------------------------------------------------------
# 当前版本(V1)暂不使用这些配置，保留为未来扩展点

# AI服务API地址（可选）
# 用途：连接外部AI服务端点
# 相关需求：13.5
NEXT_PUBLIC_AI_API_URL=

# AI服务API密钥（可选）
# 用途：AI服务认证
# 注意：此变量仅在服务端使用，不会暴露到客户端
# 相关需求：13.5
AI_API_KEY=

# -----------------------------------------------------------------------------
# 使用说明
# -----------------------------------------------------------------------------
# 1. 开发环境：复制此文件为 .env.local
# 2. 填入实际的 NEXT_PUBLIC_SITE_URL（开发环境可使用 http://localhost:3000）
# 3. AI相关变量暂时留空，V3版本实现AI功能时再配置
#
# Vercel部署说明：
# - 在Vercel项目设置 > Environment Variables 中添加相应变量
# - NEXT_PUBLIC_ 前缀的变量会自动暴露到客户端
# - 部署命令：vercel deploy（零配置部署）
